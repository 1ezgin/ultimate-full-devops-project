pipeline {
    agent any

    stages {
        stage('Git Checkout') {
            steps {
                git branch: 'main', 
                    credentialsId: '1ezgin', 
                    url: 'https://github.com/1ezgin/ultimate-full-devops-project.git'
            }
        }
        
        stage('Kubernetes Deployment') {
            steps {
                script {
                    withKubeConfig(
                        caCertificate: '', 
                        clusterName: 'amir-project-cluster', 
                        credentialsId: 'k8-token', 
                        namespace: 'webapps', 
                        serverUrl: 'https://96D7D7E2408358362593950D9CF68C95.gr7.eu-central-1.eks.amazonaws.com'
                    ) {
                        dir('Mega-Project-CD-main/Manifest') {
                            sh "kubectl apply -f manifest.yaml -n webapps"
                            sh "kubectl apply -f HPA.yaml -n webapps"
                            sh "kubectl apply -f ci.yaml"
                            sh "kubectl apply -f ingress.yaml -n webapps"
    
                            echo "Waiting 30 seconds for AWS and Kubernetes to spin up resources..."
                            sleep 30 
                            
                            echo "Deployment finished! Checking status..."
                            sh "kubectl get all -n webapps"
                        }
                    }
                }
            }
        }
    }
}
