pipeline {
    agent any

    tools {
        maven 'maven3'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        IMAGE_TAG = "v${BUILD_NUMBER}" 
    }

    stages {
        stage('Compile') {
            steps {
                dir('Mega-Project-CI-main') {
                    sh "mvn clean compile"
                }
            }
        }

        stage('Testing') {
            steps {
                dir('Mega-Project-CI-main') {
                    sh "mvn test"
                }
            }
        }

        stage('Package Application') {
            steps {
                dir('Mega-Project-CI-main') {
                    sh "mvn package -DskipTests" 
                }
            }
        }

        stage('Sonar Analysis') {
            steps {
                dir('Mega-Project-CI-main') {
                    withSonarQubeEnv('sonar') {
                        sh """
                            $SCANNER_HOME/bin/sonar-scanner \
                            -Dsonar.projectKey=gcbank \
                            -Dsonar.projectName=gcbank \
                            -Dsonar.java.binaries=target
                        """
                    }
                }
            }
        }

        stage('Quality Gate Check') {
            steps {
                dir('Mega-Project-CI-main') {
                    timeout(time: 1, unit: 'HOURS') {
                        waitForQualityGate abortPipeline: false 
                    }
                }
            }
        }

        stage('Trivy FS Scan') {
            steps {
                dir('Mega-Project-CI-main') {
                    sh "trivy fs --format table -o fs-report.html ."
                }
            }
        }

        stage('Publish to Nexus') { 
            steps { 
                dir('Mega-Project-CI-main') {
                    withMaven(globalMavenSettingsConfig: 'devops-amir', maven: 'maven3', traceability: true) {
                        sh "mvn deploy -DskipTests"
                    }
                }
            } 
        }

        stage('Docker Build, Tag & Push') {
            steps {
                dir('Mega-Project-CI-main') {
                    script {
                        withDockerRegistry(credentialsId: 'docker-cred') {
                            sh "docker build -t 1ezgin/bankapp:${IMAGE_TAG} ."
                            sh "docker push 1ezgin/bankapp:${IMAGE_TAG}"
                        }
                    }
                }
            }
        }

        stage('Scan Image') {
            steps {
                dir('Mega-Project-CI-main') {
                    sh "trivy image --format table -o image-report.html 1ezgin/bankapp:${IMAGE_TAG}"
                }
            }
        }

        stage('Update Manifest File') {
            steps {
                script {
                    dir('Mega-Project-CD-main/Manifest') {
                        sh "sed -i 's|1ezgin/bankapp:.*|1ezgin/bankapp:${IMAGE_TAG}|' manifest.yaml"
                        
                        withCredentials([usernamePassword(credentialsId: 'token-github', usernameVariable: 'GIT_USERNAME', passwordVariable: 'GIT_PASSWORD')]) {
                            sh """
                                git config user.name "Jenkins"
                                git config user.email "jenkins@example.com"
                                git add manifest.yaml
                                
                                if git diff-index --quiet HEAD; then
                                    echo "No changes to commit"
                                else
                                    git commit -m "Update image tag to ${IMAGE_TAG}"
                                    git push https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com/1ezgin/ultimate-full-devops-project.git HEAD:main
                                fi
                            """
                        }
                    }
                }
            }
        }
    }
}
